# AI models (never commit — too large)
models/*.gguf
models/*.bin
models/*.onnx
models/downloads/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Secrets
*.key
*.pem
*.env
